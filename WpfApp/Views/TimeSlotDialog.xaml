<Window x:Class="ClassDutyHelper.Views.TimeSlotDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="时间段设置" Height="540" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="20" 
            Background="{StaticResource PrimaryGradientBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000" Direction="270"/>
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="时间段设置" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,24" 
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="名称" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="NameTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="开始时间" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="StartTimeTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Text="08:00"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="结束时间" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="EndTimeTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Text="12:00"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="选择显示项目" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <Border Background="{StaticResource TertiaryBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="12" 
                            Padding="12" 
                            MaxHeight="150"
                            Margin="0,0,0,20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ProjectsPanel"/>
                        </ScrollViewer>
                    </Border>

                    <CheckBox x:Name="IsEnabledCheckBox" 
                              Content="启用" 
                              IsChecked="True" 
                              Style="{StaticResource ModernCheckBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="0,20,0,0">
                    <Button Content="确定" 
                            Click="OnOkClick" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,12,0"/>
                    <Button Content="取消" 
                            Click="OnCancelClick" 
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
