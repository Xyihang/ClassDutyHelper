<Window x:Class="ClassDutyHelper.Views.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="排班编辑" Height="380" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="20" 
            Background="{StaticResource PrimaryGradientBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000" Direction="270"/>
        </Border.Effect>
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="排班编辑" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,24" 
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="值日项目" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="ProjectComboBox" 
                          Style="{StaticResource ModernComboBoxStyle}"
                          DisplayMemberPath="Name" 
                          SelectedValuePath="Id"
                          Margin="0,0,0,20"/>

                <TextBlock Text="值日人员" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="StudentComboBox" 
                          Style="{StaticResource ModernComboBoxStyle}"
                          DisplayMemberPath="Name" 
                          SelectedValuePath="Id"
                          Margin="0,0,0,20"/>

                <TextBlock Text="备注" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="RemarkTextBox" 
                         Style="{StaticResource ModernTextBoxStyle}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="确定" 
                        Click="OnOkClick" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,12,0"/>
                <Button Content="取消" 
                        Click="OnCancelClick" 
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
