<Page x:Class="ClassDutyHelper.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="32,32,32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="历史记录" 
                               FontSize="24" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="查看值日历史记录" 
                               FontSize="14" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                            Content="导出记录"
                            Padding="20,12"
                            Command="{Binding ExportHistoryCommand}"
                            Margin="0,0,12,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                            Content="清除记录"
                            Padding="20,12"
                            Command="{Binding ClearHistoryCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="32,0,32,32">
            <Border Style="{StaticResource CardStyle}">
                <DataGrid x:Name="HistoryDataGrid"
                          Style="{StaticResource ModernDataGridStyle}"
                          ItemsSource="{Binding HistoryList}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" 
                                            Binding="{Binding Date}"
                                            Width="150"/>
                        <DataGridTextColumn Header="值日生" 
                                            Binding="{Binding DutyNames}"
                                            Width="*"/>
                        <DataGridTextColumn Header="备注" 
                                            Binding="{Binding Note}"
                                            Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>
    </Grid>
</Page>
