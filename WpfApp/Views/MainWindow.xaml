<Window x:Class="ClassDutyHelper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="班级值日助手"
        Height="780"
        Width="1280"
        MinHeight="640"
        MinWidth="1000"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        x:Name="ThisWindow"
        Loaded="OnWindowLoaded">
    <Border x:Name="WindowBorder"
            CornerRadius="20"
            Background="{StaticResource PrimaryGradientBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    CornerRadius="20,20,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnMouseLeftButtonDown">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="{StaticResource AccentGradientBrush}" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="📋" 
                                       FontSize="18" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="班级值日助手" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <RadioButton x:Name="NavToday" 
                                     Content="今日值日" 
                                     IsChecked="True"
                                     Checked="OnNavigationChanged"
                                     Style="{StaticResource NavigationRadioButtonStyle}"
                                     Margin="0,0,6,0"/>
                        <RadioButton x:Name="NavSchedule" 
                                     Content="值日安排"
                                     Checked="OnNavigationChanged"
                                     Style="{StaticResource NavigationRadioButtonStyle}"
                                     Margin="6,0"/>
                        <RadioButton x:Name="NavStudents" 
                                     Content="学生管理"
                                     Checked="OnNavigationChanged"
                                     Style="{StaticResource NavigationRadioButtonStyle}"
                                     Margin="6,0"/>
                        <RadioButton x:Name="NavProjects" 
                                     Content="项目管理"
                                     Checked="OnNavigationChanged"
                                     Style="{StaticResource NavigationRadioButtonStyle}"
                                     Margin="6,0"/>
                        <RadioButton x:Name="NavReminders" 
                                     Content="提醒管理"
                                     Checked="OnNavigationChanged"
                                     Style="{StaticResource NavigationRadioButtonStyle}"
                                     Margin="6,0"/>
                        <RadioButton x:Name="NavSettings" 
                                     Content="设置"
                                     Checked="OnNavigationChanged"
                                     Style="{StaticResource NavigationRadioButtonStyle}"
                                     Margin="6,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PinButton" 
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="置顶"
                                Click="OnPinClick">
                            <TextBlock Text="📌" FontSize="16"/>
                        </Button>
                        <Button x:Name="MinimizeButton" 
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="最小化"
                                Click="OnMinimizeClick">
                            <TextBlock Text="─" FontSize="18" FontWeight="Bold"/>
                        </Button>
                        <Button x:Name="CloseButton" 
                                Style="{StaticResource CloseButtonStyle}"
                                ToolTip="关闭"
                                Click="OnCloseClick">
                            <TextBlock Text="✕" FontSize="14" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ContentControl x:Name="TodayView">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28">
                            <Border Style="{StaticResource CardStyle}" Padding="0">
                                <StackPanel Margin="24">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock x:Name="TodayDateText" 
                                                   Text="" 
                                                   FontSize="28" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TodayWeekText" 
                                               Text="" 
                                               FontSize="15" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Style="{StaticResource CardStyle}" Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="今日值日项目" 
                                               FontSize="16" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,16"/>
                                    <TextBlock x:Name="NoDutyText" 
                                               Text="暂无值日安排" 
                                               Foreground="{StaticResource TextMutedBrush}" 
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"
                                               Padding="40"/>
                                    <ItemsControl x:Name="TodayDutyList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource TertiaryBackgroundBrush}" 
                                                        CornerRadius="12" 
                                                        Padding="18" 
                                                        Margin="0,0,0,12"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding ProjectName}" 
                                                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                                                       FontSize="16" 
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding StudentsText}" 
                                                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                                                       FontSize="14"
                                                                       Margin="0,6,0,0"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" 
                                                                Background="{StaticResource AccentBrush}"
                                                                CornerRadius="8"
                                                                Padding="12,6"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding PersonCountText}" 
                                                                       Foreground="White" 
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </ContentControl>

                <ContentControl x:Name="ScheduleView" Visibility="Collapsed">
                    <Grid Margin="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,20,0">
                            <StackPanel>
                                <Calendar x:Name="ScheduleCalendar"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="值日记录" 
                                               FontSize="16" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="自动排班" 
                                            Click="OnAutoScheduleClick"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="16,0,8,0"/>
                                    <Button Content="清空当天" 
                                            Click="OnClearScheduleClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="清空范围" 
                                            Click="OnClearScheduleRangeClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="清空全部" 
                                            Click="OnClearAllScheduleClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="导入" 
                                            Click="OnImportScheduleClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="导出" 
                                            Click="OnExportScheduleClick"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <DataGrid x:Name="ScheduleDataGrid" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="时间段" Binding="{Binding TimeSlotProject.Name}" Width="*"/>
                                            <DataGridTextColumn Header="学生" Binding="{Binding Student.Name}" Width="*"/>
                                            <DataGridTextColumn Header="项目" Binding="{Binding DutyProject.Name}" Width="*"/>
                                            <DataGridTemplateColumn Header="操作" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="编辑" 
                                                                    Click="OnEditScheduleClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"
                                                                    Margin="0,0,8,0"/>
                                                            <Button Content="删除" 
                                                                    Click="OnDeleteScheduleClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </ContentControl>

                <ContentControl x:Name="StudentsView" Visibility="Collapsed">
                    <Grid Margin="28">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="学生列表" 
                                               FontSize="16" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="添加学生" 
                                            Click="OnAddStudentClick"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="16,0,8,0"/>
                                    <Button Content="导入Excel" 
                                            Click="OnImportStudentsClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="导出Excel" 
                                            Click="OnExportStudentsClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="清空名单" 
                                            Click="OnClearStudentsClick"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <DataGrid x:Name="StudentsDataGrid" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="学号" Binding="{Binding StudentId}" Width="*"/>
                                            <DataGridTemplateColumn Header="操作" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="编辑" 
                                                                    Click="OnEditStudentClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"
                                                                    Margin="0,0,8,0"/>
                                                            <Button Content="删除" 
                                                                    Click="OnDeleteStudentClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </ContentControl>

                <ContentControl x:Name="ProjectsView" Visibility="Collapsed">
                    <Grid Margin="28">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="值日项目" 
                                               FontSize="16" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="添加项目" 
                                            Click="OnAddProjectClick"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="16,0,8,0"/>
                                    <Button Content="导入Excel" 
                                            Click="OnImportProjectsClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="导出Excel" 
                                            Click="OnExportProjectsClick"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <DataGrid x:Name="ProjectsDataGrid" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                                            <DataGridTemplateColumn Header="操作" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="编辑" 
                                                                    Click="OnEditProjectClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"
                                                                    Margin="0,0,8,0"/>
                                                            <Button Content="删除" 
                                                                    Click="OnDeleteProjectClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </ContentControl>

                <ContentControl x:Name="RemindersView" Visibility="Collapsed">
                    <Grid Margin="28">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="提醒列表" 
                                               FontSize="16" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="添加提醒" 
                                            Click="OnAddReminderClick"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="16,0,8,0"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <DataGrid x:Name="RemindersDataGrid" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="标题" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="时间" Binding="{Binding TimeText}" Width="*"/>
                                            <DataGridTemplateColumn Header="操作" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="编辑" 
                                                                    Click="OnEditReminderClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"
                                                                    Margin="0,0,8,0"/>
                                                            <Button Content="删除" 
                                                                    Click="OnDeleteReminderClick"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </ContentControl>

                <ContentControl x:Name="SettingsView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="基本设置" 
                                               FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontSize="18" 
                                               Margin="0,0,0,20"/>
                                    <TextBlock Text="班级名称" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <TextBox x:Name="ClassNameTextBox" 
                                               Style="{StaticResource ModernTextBoxStyle}"
                                               Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="显示顶栏" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ShowTopBarCheckBox" 
                                                Style="{StaticResource ModernCheckBoxStyle}"
                                                Content="启用顶栏显示"
                                                Checked="OnTopBarSettingChanged"
                                                Unchecked="OnTopBarSettingChanged"
                                                Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="顶栏透明度" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <Slider x:Name="TopBarOpacitySlider" 
                                            Minimum="30" 
                                            Maximum="100" 
                                            Value="80"
                                            ValueChanged="OnTopBarOpacityChanged"
                                            Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="顶栏高度" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <Slider x:Name="TopBarHeightSlider" 
                                            Minimum="30" 
                                            Maximum="100" 
                                            Value="60"
                                            ValueChanged="OnTopBarHeightChanged"
                                            Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="顶栏位置" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <ComboBox x:Name="TopBarPositionComboBox" 
                                                Margin="0,0,0,20"
                                                SelectionChanged="OnTopBarPositionChanged">
                                        <ComboBoxItem Content="顶部" Tag="0"/>
                                        <ComboBoxItem Content="底部" Tag="1"/>
                                        <ComboBoxItem Content="左侧" Tag="2"/>
                                        <ComboBoxItem Content="右侧" Tag="3"/>
                                    </ComboBox>
                                    
                                    <CheckBox x:Name="StartupCheckBox" 
                                                Style="{StaticResource ModernCheckBoxStyle}"
                                                Content="开机启动"
                                                Checked="OnStartupChanged"
                                                Unchecked="OnStartupChanged"
                                                Margin="0,0,0,16"/>
                                    <CheckBox x:Name="TopMostCheckBox" 
                                                Style="{StaticResource ModernCheckBoxStyle}"
                                                Content="窗口置顶"
                                                Checked="OnTopMostChanged"
                                                Unchecked="OnTopMostChanged"
                                                Margin="0,0,0,16"/>
                                    <CheckBox x:Name="HideOnStartCheckBox" 
                                                Style="{StaticResource ModernCheckBoxStyle}"
                                                Content="启动时隐藏主窗口"
                                                Checked="OnHideOnStartChanged"
                                                Unchecked="OnHideOnStartChanged"
                                                Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="云表单 URL" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <TextBox x:Name="CloudFormUrlTextBox" 
                                               Style="{StaticResource ModernTextBoxStyle}"
                                               Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="管理密钥" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <TextBox x:Name="AdminKeyTextBox" 
                                               Style="{StaticResource ModernTextBoxStyle}"
                                               Margin="0,0,0,24"/>
                                    
                                    <TextBlock Text="时间段管理" 
                                               FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimaryBrush}" 
                                               FontSize="16" 
                                               Margin="0,0,0,16"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Button Content="添加时间段" 
                                                Click="OnAddTimeSlotClick"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,0,8,0"/>
                                    </StackPanel>
                                    <DataGrid x:Name="TimeSlotDataGrid" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              Margin="0,0,0,12">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime}" Width="*"/>
                                            <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime}" Width="*"/>
                                            <DataGridTemplateColumn Header="操作" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="编辑" 
                                                                    Click="OnEditTimeSlotClick"
                                                                    Tag="{Binding}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"
                                                                    Margin="0,0,8,0"/>
                                                            <Button Content="删除" 
                                                                    Click="OnDeleteTimeSlotClick"
                                                                    Tag="{Binding}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="8,4"
                                                                    FontSize="12"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="备份数据" 
                                                Click="OnBackupClick"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="恢复数据" 
                                                Click="OnRestoreClick"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
