<Window x:Class="ClassDutyHelper.Views.DateRangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择日期范围" Height="340" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="20" 
            Background="{StaticResource PrimaryGradientBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000" Direction="270"/>
        </Border.Effect>
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="选择日期范围" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,24" 
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="开始日期" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <DatePicker x:Name="StartDatePicker" 
                            Padding="12,8"
                            FontSize="14"
                            Margin="0,0,0,20"/>

                <TextBlock Text="结束日期" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <DatePicker x:Name="EndDatePicker" 
                            Padding="12,8"
                            FontSize="14"/>
            </StackPanel>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="确定" 
                        Click="OnOkClick" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,12,0"/>
                <Button Content="取消" 
                        Click="OnCancelClick" 
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
